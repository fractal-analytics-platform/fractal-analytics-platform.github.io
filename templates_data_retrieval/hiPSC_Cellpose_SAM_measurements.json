{
  "name": "hiPSC Cellpose SAM & measurements",
  "version": 3,
  "description": "Cellpose-SAM segmentation & measurements in a small dataset of human induced pluripotent stem cells.\nWhile the initial data is in 3D, it's segmented in 2D after a maximum intensity projection.\nExample input data is available at: https://zenodo.org/records/8287221",
  "data": {
    "name": "hiPSC Cellpose SAM & measurements",
    "description": "Cellpose-SAM segmentation & measurements in a small dataset of human induced pluripotent stem cells.\nWhile the initial data is in 3D, it's segmented in 2D after a maximum intensity projection.\nExample input data is available at: https://zenodo.org/records/8287221",
    "task_list": [
      {
        "meta_non_parallel": {
          "cpus_per_task": 1,
          "mem": 4000
        },
        "meta_parallel": {
          "cpus_per_task": 1,
          "mem": 4000
        },
        "args_non_parallel": {
          "overwrite": true,
          "num_levels": 5,
          "coarsening_xy": 2,
          "image_extension": "png",
          "allowed_channels": [
            {
              "color": "0000FF",
              "label": "DAPI",
              "active": true,
              "window": {
                "end": 700,
                "start": 110
              },
              "inverted": false,
              "coefficient": 1,
              "wavelength_id": "A01_C01"
            }
          ]
        },
        "args_parallel": {
          "chunk_sizes": {
            "c": 1,
            "z": 10
          }
        },
        "type_filters": {},
        "description": "Input data is available at: https://zenodo.org/records/8287221 For your dataset, switch this converter tasks with one for your microscope.",
        "alias": null,
        "task": {
          "pkg_name": "fractal-tasks-core",
          "version": "1.6.0",
          "name": "Convert Cellvoyager to OME-Zarr"
        }
      },
      {
        "meta_non_parallel": {
          "cpus_per_task": 1,
          "mem": 4000
        },
        "meta_parallel": {
          "cpus_per_task": 1,
          "mem": 4000
        },
        "args_non_parallel": {
          "method": "Maximum intensity projection",
          "overwrite": true,
          "output_plate_name": "{plate_name}_{method}",
          "re_initialize_plate": false
        },
        "args_parallel": null,
        "type_filters": {},
        "description": null,
        "alias": null,
        "task": {
          "pkg_name": "fractal-tasks-core",
          "version": "2.0.0",
          "name": "Project Image (HCS Plate)"
        }
      },
      {
        "meta_non_parallel": null,
        "meta_parallel": {
          "cpus_per_task": 1,
          "mem": 4000,
          "needs_gpu": true
        },
        "args_non_parallel": null,
        "args_parallel": {
          "channels": {
            "mode": "label",
            "identifiers": [
              "DAPI"
            ],
            "skip_if_missing": false
          },
          "overwrite": true,
          "label_name": "nuclei",
          "advanced_parameters": {
            "bsize": 256,
            "do_3D": true,
            "invert": false,
            "augment": false,
            "verbose": false,
            "min_size": 15,
            "resample": true,
            "batch_size": 8,
            "tile_overlap": 0.1,
            "flow3D_smooth": 0,
            "normalization": {
              "mode": "default"
            },
            "flow_threshold": 0.4,
            "stitch_threshold": 0,
            "max_size_fraction": 0.4,
            "cellprob_threshold": 0
          },
          "create_masking_roi_table": {
            "mode": "Create Masking ROI Table",
            "table_name": "{label_name}_masking_ROI_table"
          }
        },
        "type_filters": {},
        "description": null,
        "alias": null,
        "task": {
          "pkg_name": "fractal-cellpose-sam-task",
          "version": "0.2.0",
          "name": "Cellpose SAM Segmentation"
        }
      },
      {
        "meta_non_parallel": {},
        "meta_parallel": {
          "cpus_per_task": 1,
          "mem": 4000
        },
        "args_non_parallel": null,
        "args_parallel": {
          "features": [
            {
              "type": "ShapeFeatures",
              "include_convex_hull_properties": false
            },
            {
              "type": "IntensityFeatures"
            }
          ],
          "overwrite": true,
          "advanced_options": {
            "use_cache": true,
            "use_scaling": true,
            "table_backend": "anndata"
          },
          "input_label_name": "nuclei",
          "output_table_name": "region_props_features"
        },
        "type_filters": {},
        "description": null,
        "alias": null,
        "task": {
          "pkg_name": "fractal-tasks-core",
          "version": "2.0.0",
          "name": "Measure Features"
        }
      }
    ]
  }
}